<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart README Builder</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
  
    <header class="box-shadow">
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
            <div class="container-fluid d-flex justify-content-between align-items-center">
                <a class="fw-bold navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Smart README Builder</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarText" aria-controls="navbarText" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarText">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-4">
                        @* <li class="nav-item">
                            <a class="nav-link active" aria-current="page" href="#">Home</a> 
                            <form asp-action="Index" asp-controller="Home" method="post">
                                <button type="submit" class="btn btn-link fw-bold nav-link">Authorize GitHub</button>
                            </form>
                            @* <a class="fw-bold nav-link" asp-area="" asp-controller="Home" asp-action="Index">Authorize GitHub</a> 
                        </li> *@
                        <li class="nav-item">
                            <a class="fw-bold nav-link" asp-area="" asp-controller="Log" asp-action="Index">View Prompts</a>
                        </li>
                        <li class="nav-item">
                            <a class="fw-bold nav-link btn-outline" asp-area="" asp-controller="Home" asp-action="Index">Generate ReadMe</a>
                        </li>
                        @* @if (TempData["GitHubLogin"] != null)
                        {
                            <li class="nav-item">
                                <a class="fw-bold nav-link" asp-area="" asp-controller="Log" asp-action="DisconnectGitHub">Disconnect GitHub</a>
                            </li>
                        } else
                        {
                            <li class="nav-item">
                                <a class="fw-bold nav-link" asp-area="" asp-controller="Home" asp-action="Authorize">Authorize GitHub</a>
                            </li>
                        } *@

                        @if (TempData["GitHubLogin"] == null)
                        {
                            <li class="nav-item">
                                <a class="fw-bold nav-link" asp-area="" asp-controller="Home" asp-action="Authorize">Authorize GitHub</a>
                            </li>
                        }

                    </ul>
                    
                </div>
            </div>
        </nav>



        @* <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light">
            <div class="container-fluid">
                <div class="d-flex justify-content-between align-items-center w-100">
                    <a class="fw-bold navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Smart README Builder</a>
                    <ul>
                        <li class="nav-item">
                            <a class="fw-bold nav-link" asp-area="" asp-controller="Home" asp-action="Index">Authorize GitHub</a>
                        </li>
                        <li class="nav-item">
                            <a class="fw-bold nav-link" asp-area="" asp-controller="Log" asp-action="Index">View Prompts</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav> *@
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <footer class="text-muted">
        <div class="container-fluid">
            <p class="text-center m-0"> &copy; 2025 - Smart README Builder - Made by <a href="https://github.com/SashanaFarrier" target="_blank">Sashana Farrier.</a></p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
