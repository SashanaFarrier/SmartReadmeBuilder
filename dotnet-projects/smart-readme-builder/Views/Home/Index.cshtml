@using SmartReadmeBuilder.Models
@model Prompt

@{
    ViewData["Title"] = "Smart README Builder";
}

<section id="generate-prompt">
    <div class="container d-flex flex-column justify-content-center align-items-center h-100">
        @if (TempData["GitHubLogin"] != null)
        {
            <div class="alert text-center w-50 mx-auto">
                @* <p class="mb-0">You are connected to GitHub as <strong>@User.Identity.Name</strong>. <a class="" asp-area="" asp-controller="Log" asp-action="DisconnectGitHub">Manage GitHub access</a></p> *@
                
                @* <a href="https://github.com/settings/applications" target="_blank">Manage GitHub access</a> *@
            </div>
        }
        <div class="svg-file-icon">
            <svg xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 640 640">
                <path d="M192 112L304 112L304 200C304 239.8 336.2 272 376 272L464 272L464 512C464 520.8 456.8 528 448 528L192 528C183.2 528 176 520.8 176 512L176 128C176 119.2 183.2 112 192 112zM352 131.9L444.1 224L376 224C362.7 224 352 213.3 352 200L352 131.9zM192 64C156.7 64 128 92.7 128 128L128 512C128 547.3 156.7 576 192 576L448 576C483.3 576 512 547.3 512 512L512 250.5C512 233.5 505.3 217.2 493.3 205.2L370.7 82.7C358.7 70.7 342.5 64 325.5 64L192 64zM248 320C234.7 320 224 330.7 224 344C224 357.3 234.7 368 248 368L392 368C405.3 368 416 357.3 416 344C416 330.7 405.3 320 392 320L248 320zM248 416C234.7 416 224 426.7 224 440C224 453.3 234.7 464 248 464L392 464C405.3 464 416 453.3 416 440C416 426.7 405.3 416 392 416L248 416z" />


            </svg>
        </div>
        <h2 class="fs-1 text-center mb-3">Generate your <span>ReadMe</span>.</h2>
        <p class="text-center mb-5">Describe your project and let AI craft a professional, well-structured README for you.</p>
        <form asp-controller="Log" asp-action="CreatePrompt" method="post">
            <div asp-validation-summary="ModelOnly" class=""></div>
            <textarea asp-for="Text" id="textbox" rows="10" cols="100" placeholder="e.g. Create a README for a Node.js app built with Express and MongoDB."></textarea>
            <button type="submit" class="btn btn-outline mt-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-stars" viewBox="0 0 16 16">
                    <path d="M7.657 6.247c.11-.33.576-.33.686 0l.645 1.937a2.89 2.89 0 0 0 1.829 1.828l1.936.645c.33.11.33.576 0 .686l-1.937.645a2.89 2.89 0 0 0-1.828 1.829l-.645 1.936a.361.361 0 0 1-.686 0l-.645-1.937a2.89 2.89 0 0 0-1.828-1.828l-1.937-.645a.361.361 0 0 1 0-.686l1.937-.645a2.89 2.89 0 0 0 1.828-1.828zM3.794 1.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387A1.73 1.73 0 0 0 4.593 5.69l-.387 1.162a.217.217 0 0 1-.412 0L3.407 5.69A1.73 1.73 0 0 0 2.31 4.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387A1.73 1.73 0 0 0 3.407 2.31zM10.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.16 1.16 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.16 1.16 0 0 0-.732-.732L9.1 2.137a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732z" />
                </svg>
                Generate ReadMe
                </button>
            <span asp-validation-for="Text" class="text-danger text-center mt-2"></span>
        </form>
          
        @if (TempData["API_Error"] != null)
        {
            <div class="toast-container position-fixed bg-secondary bottom-0 end-0 p-3 my-5">
                <div id="liveToast" role="alert" aria-live="assertive" aria-atomic="true" class="toast text-black bg-danger border-0" data-bs-autohide="false">
                    <div class="toast-header justify-content-between">
                        <small id="timeAgo">Just now</small>
                        <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                    <div class="toast-body">
                        <p class="mb-0">
                            @TempData["API_Error"]
                        </p>
                    </div>
                </div>
            </div>
           
        }
    </div>
</section>
@section Scripts {
    <script>
        window.addEventListener('DOMContentLoaded', (event) => {
            var toastEl = document.querySelector('.toast');
            if (toastEl) {
                var toast = new bootstrap.Toast(toastEl);
                toast.show();
            }

            //tooltip
            const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]')
            const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl));

            //toast display timer
            const popupShownAt = new Date();

            const updateTimeAgo = () => {
                const minutes = Math.floor((Date.now() - popupShownAt.getTime()) / 60000);
                
                if(toastEl) {
                    document.getElementById("timeAgo").textContent = minutes === 1 ? `${minutes} min ago` : `${minutes} mins ago`;
                    
                } 
            }
            
        // Update every minute
        setInterval(updateTimeAgo, 60000);
        });

    </script> 

}



