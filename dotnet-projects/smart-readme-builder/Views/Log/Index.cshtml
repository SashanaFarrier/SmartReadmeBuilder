                    <span></span>
                </div>
                <img src="~/assets/folder.png" />
                @* <img src="~/assets/add-icon.png" /> *@
                <p class="fw-bold fs-5 mt-3">No readME found.</p>
                <p>Create your first prompt to get started.</p>
                <a asp-area="" asp-controller="Home" asp-action="Index" class="mt-3 | btn create-prompt-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="16" height="16" fill="#ffffff"><!--!Font Awesome Free v7.3.0 by fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M352 128C352 110.3 337.7 96 320 96C302.3 96 288 110.3 288 128L288 288L128 288C110.3 288 96 302.3 96 320C96 337.7 110.3 352 128 352L288 352L288 512C288 529.7 302.3 544 320 544C337.7 544 352 529.7 352 512L352 352L512 352C529.7 352 544 337.7 544 320C544 302.3 529.7 288 512 288L352 288L352 128z" /></svg>
                    Create a prompt
                </a>
            </div>
        </div>
    }

    @if (TempData["GitHubLogin"] != null && ViewBag.Log.Prompts.Count > 0)
    {
        <div class="container-fluid d-flex align-items-center p-4 | log-container__content">
            <div class="d-flex align-items-center flex-grow-1 gap-4 | msg-content">
                <div class="svg-file-icon">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         viewBox="0 0 640 640">
                        <path d="M192 112L304 112L304 200C304 239.8 336.2 272 376 272L464 272L464 512C464 520.8 456.8 528 448 528L192 528C183.2 528 176 520.8 176 512L176 128C176 119.2 183.2 112 192 112zM352 131.9L444.1 224L376 224C362.7 224 352 213.3 352 200L352 131.9zM192 64C156.7 64 128 92.7 128 128L128 512C128 547.3 156.7 576 192 576L448 576C483.3 576 512 547.3 512 512L512 250.5C512 233.5 505.3 217.2 493.3 205.2L370.7 82.7C358.7 70.7 342.5 64 325.5 64L192 64zM248 320C234.7 320 224 330.7 224 344C224 357.3 234.7 368 248 368L392 368C405.3 368 416 357.3 416 344C416 330.7 405.3 320 392 320L248 320zM248 416C234.7 416 224 426.7 224 440C224 453.3 234.7 464 248 464L392 464C405.3 464 416 453.3 416 440C416 426.7 405.3 416 392 416L248 416z" />
                    </svg>
                </div>
                <div class="alert mb-3 | welcome-msg">
                    <p class="fs-4">Welcome back, <strong>@User?.Identity?.Name</strong>! 👋 </p>
                    <p>You're currently connected to your GitHub account.</p>
                    @* <a href="https://github.com/settings/applications" target="_blank">Manage GitHub access</a> *@
                    <a class="fw-bold fs-6" asp-area="" asp-controller="Log" asp-action="DisconnectGitHub" target="_blank">
                        Manage GitHub access
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="14" height="20" fill="#C19AB7"><!--!Font Awesome Free v7.3.0 by fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M439.1 297.4C451.6 309.9 451.6 330.2 439.1 342.7L279.1 502.7C266.6 515.2 246.3 515.2 233.8 502.7C221.3 490.2 221.3 469.9 233.8 457.4L371.2 320L233.9 182.6C221.4 170.1 221.4 149.8 233.9 137.3C246.4 124.8 266.7 124.8 279.2 137.3L439.2 297.3z" /></svg>
                    </a>
                </div>
            </div>
            @* <img src="~/assets/file.png" /> *@
            <div class="d-flex justify-content-between align-items-center gap-4 | connection-alert">
                <div class="d-flex gap-2 | details">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="16" fill="#0B7189" height="16"><!--!Font Awesome Free v7.3.0 by fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M320 576C178.6 576 64 461.4 64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576zM320 112C205.1 112 112 205.1 112 320C112 434.9 205.1 528 320 528C434.9 528 528 434.9 528 320C528 205.1 434.9 112 320 112zM390.7 233.9C398.5 223.2 413.5 220.8 424.2 228.6C434.9 236.4 437.3 251.4 429.5 262.1L307.4 430.1C303.3 435.8 296.9 439.4 289.9 439.9C282.9 440.4 276 437.9 271.1 433L215.2 377.1C205.8 367.7 205.8 352.5 215.2 343.2C224.6 333.9 239.8 333.8 249.1 343.2L285.1 379.2L390.7 234z" /></svg>
                    <div class="texts">
                        <p class="fw-bold mb-1">GitHub connected</p>
                        <p class="m-0">@User?.Identity?.Name</p>
                    </div>
                   
                </div>
